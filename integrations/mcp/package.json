{
  "name": "erabi-mcp",
  "version": "0.1.5",
  "mcpName": "io.github.HMAKT99/erabi",
  "description": "Erabi MCP server: any MCP-capable agent can join the intent exchange and transact natively (register, discover, intent, report_outcome, pending_outcomes, confirm_outcome, my_reputation, my_earnings).",
  "license": "Apache-2.0",
  "author": "Arun (AKT) <arunkt.bm14@gmail.com> (https://github.com/HMAKT99)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "erabi-mcp": "dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@erabi/mcp-core": "workspace:*",
    "@erabi/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@erabi/bridge-x402": "workspace:*",
    "@erabi/crypto": "workspace:*",
    "@erabi/node": "workspace:*",
    "@erabi/registry": "workspace:*",
    "@types/node": "^20.19.42",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HMAKT99/Erabi.git",
    "directory": "integrations/mcp"
  },
  "homepage": "https://github.com/HMAKT99/Erabi#readme",
  "bugs": {
    "url": "https://github.com/HMAKT99/Erabi/issues"
  },
  "keywords": [
    "erabi",
    "mcp",
    "model-context-protocol",
    "agents",
    "intent-exchange"
  ],
  "publishConfig": {
    "access": "public"
  }
}
