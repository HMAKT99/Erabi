{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "codegen": {
      "inputs": ["json/**", "scripts/**"],
      "outputs": ["src/generated/**", "python/**"]
    },
    "build": {
      "dependsOn": ["^build", "codegen"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"]
    }
  }
}
