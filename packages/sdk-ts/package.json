{
  "name": "@erabi/sdk",
  "version": "0.1.1",
  "description": "Erabi Protocol SDK for TypeScript agents: register, fire intents, report outcomes, get paid — three lines to join the intent exchange.",
  "license": "Apache-2.0",
  "author": "Arun (AKT) <arunkt.bm14@gmail.com> (https://github.com/HMAKT99)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@erabi/constants": "workspace:*",
    "@erabi/crypto": "workspace:*",
    "@erabi/schemas": "workspace:*"
  },
  "devDependencies": {
    "@erabi/node": "workspace:*",
    "@types/node": "^20.19.42",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HMAKT99/Erabi.git",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/HMAKT99/Erabi#readme",
  "bugs": {
    "url": "https://github.com/HMAKT99/Erabi/issues"
  },
  "keywords": [
    "erabi",
    "agents",
    "sdk",
    "intent-exchange",
    "mcp",
    "x402"
  ],
  "publishConfig": {
    "access": "public"
  }
}
